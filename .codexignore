# Keep Codex focused on source code and small config files.
# These rules do not delete files and do not affect Git tracking.

# Repository internals, dependencies, caches, and generated output
.git/
.github/
node_modules/
dist/
.vite/
*.tsbuildinfo
*.log
.vite-*.log
package-lock.json
.env

# Local screenshots, QA output, and temporary work areas
asset_work/
qa-screenshots/
home-*.png
image.png
新建 文本文档.txt

# Large design/source-material folders. Codex does not need to index these
# on every message; the app still reads assets from disk normally.
UI素材整理/
UI设计方案/
ui设计参考/
ui元素/
古城素材/
public/assets/

# Backups/recovery snapshots kept for manual reference only
src/*.broken-backup-*.tsx
src/*.broken-backup-*.css
src/*.overwritten-*.tsx
src/*.overwritten-*.css

# Binary/media files are expensive for Codex context.
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.svg
*.psd
*.ai
*.zip
*.rar
*.7z
*.mp4
*.mov
*.avi
*.docx
*.pptx
*.xlsx
